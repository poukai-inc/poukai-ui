{
  "name": "@poukai-inc/ui",
  "version": "1.3.0",
  "description": "Poukai design system — React component library, design tokens, and brand assets.",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./atoms": {
      "types": "./dist/atoms.d.ts",
      "import": "./dist/atoms.js",
      "require": "./dist/atoms.cjs"
    },
    "./molecules": {
      "types": "./dist/molecules.d.ts",
      "import": "./dist/molecules.js",
      "require": "./dist/molecules.cjs"
    },
    "./organisms": {
      "types": "./dist/organisms.d.ts",
      "import": "./dist/organisms.js",
      "require": "./dist/organisms.cjs"
    },
    "./atoms/Avatar": {
      "types": "./dist/atoms/Avatar.d.ts",
      "import": "./dist/atoms/Avatar.js",
      "require": "./dist/atoms/Avatar.cjs"
    },
    "./atoms/Icon": {
      "types": "./dist/atoms/Icon.d.ts",
      "import": "./dist/atoms/Icon.js",
      "require": "./dist/atoms/Icon.cjs"
    },
    "./atoms/Button": {
      "types": "./dist/atoms/Button.d.ts",
      "import": "./dist/atoms/Button.js",
      "require": "./dist/atoms/Button.cjs"
    },
    "./atoms/EmailLink": {
      "types": "./dist/atoms/EmailLink.d.ts",
      "import": "./dist/atoms/EmailLink.js",
      "require": "./dist/atoms/EmailLink.cjs"
    },
    "./atoms/Eyebrow": {
      "types": "./dist/atoms/Eyebrow.d.ts",
      "import": "./dist/atoms/Eyebrow.js",
      "require": "./dist/atoms/Eyebrow.cjs"
    },
    "./atoms/Stat": {
      "types": "./dist/atoms/Stat.d.ts",
      "import": "./dist/atoms/Stat.js",
      "require": "./dist/atoms/Stat.cjs"
    },
    "./atoms/StatusBadge": {
      "types": "./dist/atoms/StatusBadge.d.ts",
      "import": "./dist/atoms/StatusBadge.js",
      "require": "./dist/atoms/StatusBadge.cjs"
    },
    "./atoms/Tag": {
      "types": "./dist/atoms/Tag.d.ts",
      "import": "./dist/atoms/Tag.js",
      "require": "./dist/atoms/Tag.cjs"
    },
    "./atoms/Wordmark": {
      "types": "./dist/atoms/Wordmark.d.ts",
      "import": "./dist/atoms/Wordmark.js",
      "require": "./dist/atoms/Wordmark.cjs"
    },
    "./atoms/Link": {
      "types": "./dist/atoms/Link.d.ts",
      "import": "./dist/atoms/Link.js",
      "require": "./dist/atoms/Link.cjs"
    },
    "./molecules/FailureMode": {
      "types": "./dist/molecules/FailureMode.d.ts",
      "import": "./dist/molecules/FailureMode.js",
      "require": "./dist/molecules/FailureMode.cjs"
    },
    "./molecules/FeatureCard": {
      "types": "./dist/molecules/FeatureCard.d.ts",
      "import": "./dist/molecules/FeatureCard.js",
      "require": "./dist/molecules/FeatureCard.cjs"
    },
    "./molecules/FieldNote": {
      "types": "./dist/molecules/FieldNote.d.ts",
      "import": "./dist/molecules/FieldNote.js",
      "require": "./dist/molecules/FieldNote.cjs"
    },
    "./molecules/Hero": {
      "types": "./dist/molecules/Hero.d.ts",
      "import": "./dist/molecules/Hero.js",
      "require": "./dist/molecules/Hero.cjs"
    },
    "./molecules/LinkCard": {
      "types": "./dist/molecules/LinkCard.d.ts",
      "import": "./dist/molecules/LinkCard.js",
      "require": "./dist/molecules/LinkCard.cjs"
    },
    "./molecules/Portrait": {
      "types": "./dist/molecules/Portrait.d.ts",
      "import": "./dist/molecules/Portrait.js",
      "require": "./dist/molecules/Portrait.cjs"
    },
    "./molecules/Principle": {
      "types": "./dist/molecules/Principle.d.ts",
      "import": "./dist/molecules/Principle.js",
      "require": "./dist/molecules/Principle.cjs"
    },
    "./molecules/Pull": {
      "types": "./dist/molecules/Pull.d.ts",
      "import": "./dist/molecules/Pull.js",
      "require": "./dist/molecules/Pull.cjs"
    },
    "./molecules/Quote": {
      "types": "./dist/molecules/Quote.d.ts",
      "import": "./dist/molecules/Quote.js",
      "require": "./dist/molecules/Quote.cjs"
    },
    "./molecules/RoleCard": {
      "types": "./dist/molecules/RoleCard.d.ts",
      "import": "./dist/molecules/RoleCard.js",
      "require": "./dist/molecules/RoleCard.cjs"
    },
    "./molecules/Section": {
      "types": "./dist/molecules/Section.d.ts",
      "import": "./dist/molecules/Section.js",
      "require": "./dist/molecules/Section.cjs"
    },
    "./molecules/Statement": {
      "types": "./dist/molecules/Statement.d.ts",
      "import": "./dist/molecules/Statement.js",
      "require": "./dist/molecules/Statement.cjs"
    },
    "./molecules/TeamCard": {
      "types": "./dist/molecules/TeamCard.d.ts",
      "import": "./dist/molecules/TeamCard.js",
      "require": "./dist/molecules/TeamCard.cjs"
    },
    "./organisms/Dialog": {
      "types": "./dist/organisms/Dialog.d.ts",
      "import": "./dist/organisms/Dialog.js",
      "require": "./dist/organisms/Dialog.cjs"
    },
    "./organisms/Footer": {
      "types": "./dist/organisms/Footer.d.ts",
      "import": "./dist/organisms/Footer.js",
      "require": "./dist/organisms/Footer.cjs"
    },
    "./organisms/SiteShell": {
      "types": "./dist/organisms/SiteShell.d.ts",
      "import": "./dist/organisms/SiteShell.js",
      "require": "./dist/organisms/SiteShell.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./fonts/*": "./dist/fonts/*",
    "./brand/*": "./dist/brand/*",
    "./llms.txt": "./dist/llms.txt",
    "./llms-full.txt": "./dist/llms-full.txt"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "ladle serve",
    "build": "BUILD_TARGET=lib vite build && tsc --emitDeclarationOnly && pnpm run build:tokens && pnpm run build:brand && pnpm run build:llms",
    "build:tokens": "cpy --flat src/tokens/tokens.css dist/ && cpy 'src/tokens/fonts/**' dist/fonts",
    "build:brand": "cpy 'src/brand/**' dist/brand",
    "build:llms": "node scripts/build-llms-txt.mjs",
    "test": "playwright test -c playwright-ct.config.ts",
    "playwright:install": "playwright install chromium firefox webkit",
    "test:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:a11y": "playwright test -c playwright-ct.config.ts src/a11y.test.tsx",
    "build:wordmark": "node scripts/build-wordmark.mjs",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "showcase:build": "pnpm run build:tokens && ladle build && cpy --flat dist/tokens.css build && cpy 'dist/fonts/**' build/fonts",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "lucide-react": ">=0.500.0",
    "react": ">=18 || >=19",
    "react-dom": ">=18 || >=19"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.15",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@ladle/react": "^4.1.0",
    "@playwright/experimental-ct-react": "^1.45.0",
    "@playwright/test": "^1.45.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/react": ">=18.3.0 <20",
    "@types/react-dom": ">=18.3.0 <20",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "cpy-cli": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.0",
    "lucide-react": "^0.577.0",
    "marked": "^14.1.0",
    "postcss": "^8.4.45",
    "postcss-custom-media": "^11.0.0",
    "postcss-nesting": "^13.0.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^11.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vite-plugin-lib-inject-css": "^2.2.0"
  },
  "size-limit": [
    {
      "name": "ESM — full bundle",
      "path": "dist/index.js",
      "limit": "35 kB"
    },
    {
      "name": "ESM — atoms subpath",
      "path": "dist/atoms.js",
      "limit": "16 kB"
    },
    {
      "name": "ESM — molecules subpath",
      "path": "dist/molecules.js",
      "limit": "9 kB"
    },
    {
      "name": "ESM — organisms subpath",
      "path": "dist/organisms.js",
      "limit": "25 kB"
    },
    {
      "name": "ESM — tree-shaken (Wordmark + Button)",
      "path": "dist/index.js",
      "import": "{ Wordmark, Button }",
      "limit": "14 kB"
    },
    {
      "name": "ESM — tree-shaken (Hero + RoleCard + Principle)",
      "path": "dist/index.js",
      "import": "{ Hero, RoleCard, Principle }",
      "limit": "11 kB"
    }
  ]
}
