{
  "name": "@poukai/ui",
  "version": "0.1.0",
  "description": "Poukai design system — React component library, design tokens, and brand assets.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./atoms": {
      "types": "./dist/atoms.d.ts",
      "import": "./dist/atoms.js",
      "require": "./dist/atoms.cjs"
    },
    "./molecules": {
      "types": "./dist/molecules.d.ts",
      "import": "./dist/molecules.js",
      "require": "./dist/molecules.cjs"
    },
    "./organisms": {
      "types": "./dist/organisms.d.ts",
      "import": "./dist/organisms.js",
      "require": "./dist/organisms.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "ladle serve",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:tokens": "cpy src/tokens/tokens.css dist/ && cpy 'src/tokens/fonts/**' dist/fonts",
    "test": "playwright test -c playwright-ct.config.ts",
    "playwright:install": "playwright install chromium webkit",
    "test:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:a11y": "playwright test -c playwright-ct.config.ts src/a11y.test.tsx",
    "build:wordmark": "node scripts/build-wordmark.mjs",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "showcase:build": "ladle build",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@ladle/react": "^4.1.0",
    "@playwright/experimental-ct-react": "^1.45.0",
    "@playwright/test": "^1.45.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "cpy-cli": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.45",
    "postcss-custom-media": "^11.0.0",
    "postcss-nesting": "^13.0.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "size-limit": "^11.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "playwright-ct.config.ts": "prettier --write",
    "vite.config.ts": "prettier --write",
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "name": "ESM — full bundle",
      "path": "dist/index.js",
      "limit": "24 kB"
    },
    {
      "name": "ESM — atoms subpath",
      "path": "dist/atoms.js",
      "limit": "16 kB"
    },
    {
      "name": "ESM — molecules subpath",
      "path": "dist/molecules.js",
      "limit": "6 kB"
    },
    {
      "name": "ESM — organisms subpath",
      "path": "dist/organisms.js",
      "limit": "14 kB"
    },
    {
      "name": "ESM — tree-shaken (Wordmark + Button)",
      "path": "dist/index.js",
      "import": "{ Wordmark, Button }",
      "limit": "14 kB"
    },
    {
      "name": "ESM — tree-shaken (Hero + RoleCard + Principle)",
      "path": "dist/index.js",
      "import": "{ Hero, RoleCard, Principle }",
      "limit": "8 kB"
    }
  ]
}
